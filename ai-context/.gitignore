# В git хранится читаемый markdown-контекст и versioned metadata.
workspace/content/*.html
workspace/content/*.tmp
workspace/content/*.tmp.*

# Markdown-снимки контекста сохраняются.
!workspace/content/*.md
!workspace/content/.gitkeep

# Local-machine secrets всегда должны оставаться локальными.
workspace/parameters/local-machine/*
!workspace/parameters/local-machine/.gitignore
